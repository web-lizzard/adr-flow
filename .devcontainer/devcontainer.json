{
	"name": "Dev Container",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
	"shutdownAction": "stopCompose",
	"remoteUser": "vscode",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22",
			"pnpmVersion": "latest",
			"nvmInstallPath": "/usr/local/share/nvm"
		},
		"ghcr.io/devcontainers-extra/features/uv:1": {}
	},
	"initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/initialize.sh",
	"mounts": [
		"source=${localWorkspaceFolder}/.devcontainer/.permissions-cache/permissions.json,target=/home/vscode/.cursor/permissions.json,type=bind,consistency=cached"
	],
	"postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",
	"remoteEnv": {
		"REDIS_URL": "redis://redis:6379",
		"DATABASE_URL": "postgresql://postgres:postgres@postgres:5432/adr_flow",
		"TEST_DATABASE_URL": "postgresql://postgres:postgres@postgres:5432/adr_flow_test"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"Vue.volar",
				"Vue.vscode-typescript-vue-plugin",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"humao.rest-client",
				"GoogleCloudTools.cloudcode"
			]
		}
	}
}
