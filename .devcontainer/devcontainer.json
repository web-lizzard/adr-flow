{
	"name": "Dev Container",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"remoteUser": "vscode",
	"initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/initialize.sh",
	"mounts": [
		"source=${localWorkspaceFolder}/.devcontainer/.permissions-cache/permissions.json,target=/home/vscode/.cursor/permissions.json,type=bind,consistency=cached"
	],
	"postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"remoteEnv": {
		"REDIS_URL": "redis://redis:6379",
		"DATABASE_URL": "postgresql://dev:dev@postgres:5432/app"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"Vue.volar",
				"Vue.vscode-typescript-vue-plugin",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"humao.rest-client"
			]
		}
	}
}
