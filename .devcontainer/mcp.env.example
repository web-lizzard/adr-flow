# Copy to mcp.env (gitignored). Used by devcontainer MCP servers (see .devcontainer/MCP.md).
#
# cp .devcontainer/mcp.env.example .devcontainer/mcp.env
#
# GITHUB_PERSONAL_ACCESS_TOKEN — required for github-mcp-server in the devcontainer.
#
# Fine-grained PAT (recommended):
#   - Resource owner: your user or org; repository access: web-lizzard/adr-flow only
#   - Repository permissions: Actions (Read), Metadata (Read)
#   - Do not grant Contents, Pull requests write, or Workflow write
#
# Classic PAT (alternative, broader):
#   - Scopes: repo (read) and workflow — only if Actions read tools need more access
#
GITHUB_PERSONAL_ACCESS_TOKEN=

# Limit GitHub MCP to workflow/run tools (read-only).
GITHUB_TOOLSETS=actions
GITHUB_READ_ONLY=1
