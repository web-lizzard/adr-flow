# SSH URL to the project-assets repository (host-only; devcontainer initializeCommand).
# Must contain .cursor/skills/ and .cursor/permissions.json (sparse-checkout default: .cursor).
# Do not commit .cursor/permissions.json in project repos — it overrides the assets copy.
ASSETS_REPO=git@github.com:your-org/cursor-project-assets.git

# Path inside that repo to sparse-checkout (default: .cursor).
# ASSETS_SPARSE_PATH=.cursor

# GCP deploy (MVP single project; optional overrides for deploy/gcp scripts and just gcp-*)
# GCP_PROJECT_ID=adr-flow
# GCP_REGION=europe-west1

# Cursor MCP (devcontainer; see .devcontainer/MCP.md)
# Fine-grained PAT on web-lizzard/adr-flow: Actions (Read), Metadata (Read) only
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Backend settings (all required — no defaults in config.py).
# Devcontainer remoteEnv provides these for local dev; override here if needed:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/adr_flow
# JWT_SECRET=dev-insecure-jwt-secret-change-me-32b
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# COOKIE_SECURE=false
# COOKIE_PATH=/api
# Integration tests use TEST_DATABASE_URL only (separate DB; set in devcontainer remoteEnv):
# TEST_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/adr_flow_test
GITHUB_TOOLSETS=actions
GITHUB_READ_ONLY=1
