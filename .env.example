# SSH URL to the project-assets repository (host-only; devcontainer initializeCommand).
# Must contain .cursor/skills/ and .cursor/permissions.json (sparse-checkout default: .cursor).
# Do not commit .cursor/permissions.json in project repos — it overrides the assets copy.
ASSETS_REPO=git@github.com:your-org/cursor-project-assets.git

# Path inside that repo to sparse-checkout (default: .cursor).
# ASSETS_SPARSE_PATH=.cursor
