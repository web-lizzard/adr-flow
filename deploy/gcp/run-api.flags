# Cloud Run flags for adr-flow-api (source deploy from backend/).
# Used by deploy/gcp/deploy-api.sh and documented in deploy/gcp/README.md.
# Override project/region via .env or deploy/gcp/.bootstrap-state.env (see _common.sh).
#
# Build (set on deploy command, not in this file):
#   --set-build-env-vars=GOOGLE_PYTHON_PACKAGE_MANAGER=uv
#
# Runtime env: deploy-api.sh resolves CORS_ORIGINS from the live adr-flow-web URL.
# On first deploy (web not yet live) CORS_ORIGINS uses the fallback below;
# redeploy API after web is up to pick up the real origin.
#
--region=europe-west1
--min-instances=0
--max-instances=1
--no-cpu-throttling
--cpu-boost
--vpc-egress=private-ranges-only
--network=default
--subnet=adr-flow-cloud-run
--allow-unauthenticated
--set-secrets=DATABASE_URL=db-url:latest,JWT_SECRET=jwt-secret:latest,OPENROUTER_API_KEY=openrouter-key:latest
--set-env-vars=CORS_ORIGINS=https://placeholder.run.app,COOKIE_SECURE=true,COOKIE_PATH=/api,LLM_PROVIDER=openrouter,LLM_MODEL=openai/gpt-4o-mini,LLM_TIMEOUT_SECONDS=60
