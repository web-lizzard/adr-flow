# Copy to secrets.env (gitignored). Used by 03-gce-postgres.sh and 04-secrets.sh.
#
# GCP_BILLING_ACCOUNT — required when creating a new project (01-project-apis.sh).
#   gcloud billing accounts list
# GCP_BILLING_ACCOUNT=012345-678901-ABCDEF

# POSTGRES_PASSWORD — optional; generated on first 03 run if unset.
# POSTGRES_PASSWORD=

# JWT_SECRET — required for 04-secrets.sh (jwt-secret in Secret Manager).
#   Generate with: openssl rand -base64 32
# JWT_SECRET=

# OPENROUTER_API_KEY — required for 04-secrets.sh (openrouter-key in Secret Manager).
# OPENROUTER_API_KEY=
#
# Non-secret LLM review settings are set in deploy/gcp/run-api.flags:
# LLM_PROVIDER=openrouter, LLM_MODEL, LLM_TIMEOUT_SECONDS.
# Optional LLM_BASE_URL override for OpenRouter-compatible endpoints.
